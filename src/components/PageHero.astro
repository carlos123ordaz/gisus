---
export interface Props {
  eyebrow: string;
  title: string;
  subtitle?: string;
}
const { eyebrow, title, subtitle } = Astro.props;
---
<div class="page-hero">
  <div class="wrap">
    <p class="ph-eyebrow">{eyebrow}</p>
    <h1 class="display ph-title">{title}</h1>
    {subtitle && <p class="ph-sub">{subtitle}</p>}
  </div>
  <div class="ph-stripe"></div>
</div>

<style>
  .page-hero {
    padding: 140px 0 80px;
    background: var(--grad);
    position: relative;
    overflow: hidden;
  }
  .ph-eyebrow {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: rgba(255,255,255,.75);
    margin-bottom: 18px;
  }
  .ph-title {
    font-size: clamp(52px, 8vw, 110px);
    color: var(--ink);
    letter-spacing: -0.035em;
    line-height: 0.95;
    max-width: 14ch;
  }
  .ph-sub {
    margin-top: 24px;
    font-size: 19px;
    color: rgba(30,20,24,.72);
    max-width: 560px;
    line-height: 1.55;
  }
  .ph-stripe {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 40px,
      rgba(255,255,255,.04) 40px,
      rgba(255,255,255,.04) 80px
    );
    pointer-events: none;
  }
</style>
