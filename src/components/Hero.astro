---
---
<header class="hero">
  <div class="wrap">
    <div class="hero-stage">
      <div class="hero-eyebrow"><span class="tag-dot"></span>Detecta personas cerca de ti · En tiempo real</div>
      <h1 class="hero-word">Gisus</h1>

      <div class="pcard pc1">
        <image-slot id="hero-1" shape="rounded" radius="24" placeholder="Arrastra una foto"></image-slot>
        <div class="pcard-tag"><span class="tag-dot"></span>Ana · <b>a 8m</b></div>
      </div>
      <div class="pcard pc2">
        <image-slot id="hero-2" shape="rounded" radius="24" placeholder="Arrastra una foto"></image-slot>
        <div class="pcard-tag"><span class="tag-dot"></span>Lucas · <b>a 14m</b></div>
      </div>
      <div class="pcard pc3">
        <image-slot id="hero-3" shape="rounded" radius="24" placeholder="Arrastra una foto"></image-slot>
        <div class="pcard-tag"><span class="tag-dot"></span>Sara · <b>a 22m</b></div>
      </div>
    </div>
  </div>
</header>

<style>
  .hero { background: var(--grad); padding: 120px 0 0; position: relative; overflow: hidden; }
  .hero-stage { position: relative; height: calc(100vh - 120px); min-height: 620px; display: flex; align-items: center; justify-content: center; }
  .hero-word { font-family: var(--font-display); font-weight: 900; font-size: clamp(120px, 23vw, 360px); color: var(--ink); letter-spacing: -0.04em; line-height: 1; user-select: none; position: relative; z-index: 1; }

  .pcard { position: absolute; z-index: 2; border-radius: 24px; overflow: visible; box-shadow: 0 24px 60px rgba(30,12,20,.30); transition: transform .4s ease; background: linear-gradient(150deg, #FFD6E5, #FFB3CF); }
  .pcard image-slot { display: block; width: 100%; height: 100%; }
  .pcard::after { content: ''; position: absolute; inset: 0; border-radius: 24px; box-shadow: inset 0 0 0 1px rgba(255,255,255,.4); pointer-events: none; }
  .pcard-tag {
    position: absolute; left: 14px; bottom: 14px; z-index: 5;
    background: rgba(255,255,255,.96); color: var(--ink); font-family: var(--font-display);
    font-weight: 700; font-size: 14px; padding: 7px 14px; border-radius: 100px;
    display: inline-flex; align-items: center; gap: 7px; white-space: nowrap; flex-wrap: nowrap;
    box-shadow: 0 4px 14px rgba(30,12,20,.18); backdrop-filter: blur(4px);
  }
  .pcard-tag b { white-space: nowrap; color: var(--pink); }
  .tag-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--pink); animation: blink 1.6s infinite; display: inline-block; }

  .pc1 { width: 240px; height: 320px; top: 8%;  left: 18%;  --rot: -7deg; transition-delay: .04s; background: linear-gradient(150deg, #FFD6E5, #FF9EC0); }
  .pc2 { width: 268px; height: 350px; top: 24%; left: 41%;  --rot: 3deg;  transition-delay: .18s; z-index: 3; background: linear-gradient(150deg, #E4D7FF, #B79BFF); }
  .pc3 { width: 230px; height: 300px; top: 14%; right: 17%; --rot: 8deg;  transition-delay: .32s; background: linear-gradient(150deg, #CFF5EE, #93E0CF); }

  .hero .pcard { opacity: 0; transform: rotate(var(--rot, 0deg)) translateY(34px) scale(.92); transition: opacity .85s cubic-bezier(.22,.72,.24,1), transform .85s cubic-bezier(.22,.72,.24,1); }
  .hero .pcard.show { opacity: 1; transform: rotate(var(--rot, 0deg)) translateY(0) scale(1); }
  .hero .pcard.show:hover { transform: rotate(0deg) translateY(-8px) scale(1.03); transition-delay: 0s; }
  @media (prefers-reduced-motion: reduce) { .hero .pcard { transition-duration: .3s; } }

  .hero-eyebrow {
    position: absolute; top: 4%; left: 50%; transform: translateX(-50%); z-index: 4;
    display: inline-flex; align-items: center; gap: 9px; background: rgba(255,255,255,.92);
    color: var(--ink); font-weight: 600; font-size: 14px; padding: 8px 18px; border-radius: 100px;
    box-shadow: 0 4px 14px rgba(30,12,20,.16); white-space: nowrap;
  }

  @media (max-width: 980px) {
    .hero-stage { height: auto; min-height: 0; padding: 40px 0 60px; }
    .hero-word { font-size: clamp(90px, 26vw, 200px); }
    .pc1 { width: 130px; height: 174px; left: 4%; top: 4%; }
    .pc2 { width: 150px; height: 196px; top: 30%; left: 38%; }
    .pc3 { width: 124px; height: 164px; right: 3%; top: 12%; }
    .pcard-tag { font-size: 11px; padding: 5px 10px; }
  }
</style>

<script>
  const heroCards = document.querySelectorAll('.hero .pcard');
  let cardsReady = false;
  function updateHeroCards() {
    const visible = cardsReady && window.scrollY < 160;
    heroCards.forEach(c => c.classList.toggle('show', visible));
  }
  setTimeout(() => { cardsReady = true; updateHeroCards(); }, 2000);
  window.addEventListener('scroll', updateHeroCards, { passive: true });
</script>
