---
---
<nav id="nav">
  <div class="wrap">
    <div class="nav-row">
      <a href="/" class="logo">Gisus</a>
      <div class="nav-pill">
        <a href="/#como">Cómo funciona</a>
        <a href="/#porque">Por qué Gisus</a>
        <a href="/#app">La app</a>
      </div>
      <div class="nav-right">
        <button class="nav-globe" aria-label="Idioma">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><path d="M3 12h18M12 3c2.5 2.5 2.5 15 0 18M12 3c-2.5 2.5-2.5 15 0 18" stroke="currentColor" stroke-width="1.6"/></svg>
        </button>
        <a href="/#descargar" class="btn-dark">Descargar</a>
      </div>
    </div>
  </div>
</nav>

<style>
  nav {
    position: fixed; inset: 0 0 auto 0; z-index: 300; padding: 18px 0;
    transition: background .3s, box-shadow .3s, padding .3s;
  }
  nav.stuck { background: var(--white); box-shadow: 0 1px 0 var(--line); padding: 12px 0; }
  .nav-row { display: flex; align-items: center; justify-content: space-between; gap: 20px; }
  .logo { font-family: var(--font-display); font-weight: 800; font-size: 27px; color: var(--ink); text-decoration: none; letter-spacing: -0.02em; }
  .nav-pill {
    display: flex; align-items: center; gap: 6px; background: var(--white);
    border-radius: 100px; padding: 7px; box-shadow: 0 2px 14px rgba(30,20,24,.10);
  }
  nav.stuck .nav-pill { box-shadow: inset 0 0 0 1px var(--line); }
  .nav-pill a { color: var(--ink); text-decoration: none; font-size: 15px; font-weight: 600; padding: 9px 20px; border-radius: 100px; transition: background .2s; white-space: nowrap; }
  .nav-pill a:hover { background: var(--pink-softer); }
  .nav-right { display: flex; align-items: center; gap: 10px; }
  .nav-globe { width: 44px; height: 44px; border-radius: 50%; background: var(--white); box-shadow: 0 2px 14px rgba(30,20,24,.10); display: flex; align-items: center; justify-content: center; color: var(--ink); border: none; cursor: pointer; }
  .btn-dark {
    background: var(--ink); color: var(--white); text-decoration: none; font-family: var(--font-display);
    font-weight: 700; font-size: 15.5px; padding: 12px 26px; border-radius: 100px;
    transition: transform .2s, background .2s; display: inline-flex; align-items: center; gap: 8px; border: none; cursor: pointer;
  }
  .btn-dark:hover { transform: translateY(-2px); background: #000; }

  @media (max-width: 980px) {
    .nav-pill { display: none; }
  }
</style>

<script>
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => nav?.classList.toggle('stuck', scrollY > 30), { passive: true });
</script>
