---
---
<section class="steps-sec" id="como">
  <div class="wrap">
    <div class="sec-head fade">
      <p class="sec-eyebrow">Cómo funciona</p>
      <h2 class="display sec-title">Tres pasos. Una conexión real.</h2>
    </div>
    <div class="steps">
      <div class="step fade">
        <div class="step-visual">
          <div class="sv-radar">
            <div class="sv-disk">
              <div class="sv-ring sv-r1"></div>
              <div class="sv-ring sv-r2"></div>
              <div class="sv-sweep"></div>
              <div class="sv-you"></div>
            </div>
          </div>
        </div>
        <div class="step-n">PASO 01</div>
        <h3 class="step-h">Enciende el radar</h3>
        <p class="step-p">Abre Gisus y activa tu presencia. Empiezas a detectar quién más tiene la app activa cerca de ti, ahora mismo.</p>
      </div>
      <div class="step fade" style="transition-delay:.1s">
        <div class="step-visual">
          <div class="sv-people">
            <div class="sv-person" style="background:linear-gradient(135deg,#FF2D78,#FF6B9D)">A</div>
            <div class="sv-person" style="background:linear-gradient(135deg,#6B4FFF,#9B7FFF)">L</div>
            <div class="sv-person" style="background:linear-gradient(135deg,#2DD4BF,#06B6D4)">S</div>
          </div>
        </div>
        <div class="step-n">PASO 02</div>
        <h3 class="step-h">Aparecen personas cercanas</h3>
        <p class="step-p">En segundos ves quién comparte tu espacio físico. Cada perfil está a metros de ti, no a kilómetros.</p>
      </div>
      <div class="step fade" style="transition-delay:.2s">
        <div class="step-visual">
          <svg class="sv-bolt" viewBox="0 0 84 84" fill="none">
            <path d="M48 10L26 46h16l-6 28 28-40H46l2-24z" fill="url(#bg)"/>
            <defs><linearGradient id="bg" x1="26" y1="10" x2="64" y2="74"><stop stop-color="#FF2D78"/><stop offset="1" stop-color="#FF6B9D"/></linearGradient></defs>
          </svg>
        </div>
        <div class="step-n">PASO 03</div>
        <h3 class="step-h">Da like y conecta</h3>
        <p class="step-p">Si ambos se gustan, el match es instantáneo y el chat se abre. La conversación ocurre mientras siguen cerca.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .steps-sec { background: var(--cream); padding: 120px 0; }
  .sec-head { max-width: 640px; margin-bottom: 70px; }
  .sec-eyebrow { font-family: var(--font-display); font-size: 14px; font-weight: 700; color: var(--pink); margin-bottom: 16px; }
  .sec-title { font-size: clamp(34px, 4.4vw, 60px); }
  .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 26px; }
  .step { background: var(--white); border-radius: 28px; padding: 38px 34px; }
  .step-visual { height: 130px; display: flex; align-items: center; justify-content: center; margin-bottom: 26px; }
  .step-n { font-family: var(--font-display); font-weight: 800; font-size: 15px; color: var(--pink); margin-bottom: 10px; }
  .step-h { font-family: var(--font-display); font-weight: 800; font-size: 24px; margin-bottom: 10px; letter-spacing: -0.01em; }
  .step-p { font-size: 16px; color: var(--ink-soft); line-height: 1.55; text-wrap: pretty; }

  .sv-radar { position: relative; width: 120px; height: 120px; }
  .sv-disk { width:100%; height:100%; border-radius:50%; border:1.5px solid rgba(255,45,120,.3); background: rgba(255,45,120,.05); overflow:hidden; position:relative; }
  .sv-ring { position:absolute; border-radius:50%; border:1px solid rgba(255,45,120,.25); top:50%; left:50%; transform:translate(-50%,-50%); }
  .sv-r1{width:45%;height:45%;} .sv-r2{width:80%;height:80%;}
  .sv-sweep { position:absolute; top:50%; left:50%; width:50%; height:1.5px; transform-origin:left center; background:linear-gradient(to right,transparent,#FF2D78); animation: spin 4s linear infinite; }
  .sv-you { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:11px; height:11px; border-radius:50%; background:var(--grad); }
  .sv-people { display:flex; }
  .sv-person { width:50px; height:50px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:var(--font-display); font-weight:800; font-size:17px; color:#fff; border:3px solid var(--white); }
  .sv-person:not(:first-child){ margin-left:-16px; }
  .sv-bolt { width: 84px; height: 84px; }

  @media (max-width: 980px) {
    .steps { grid-template-columns: 1fr; }
  }
</style>
