---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Contacto — Gisus">
  <Nav />

  <PageHero
    eyebrow="Contacto"
    title="Hablemos"
    subtitle="Estamos aquí para escucharte. Elige el canal que mejor se adapte a tu consulta."
  />

  <div class="contact-wrap">

    <!-- Contact channels -->
    <div class="channels fade">
      <a href="mailto:hola@gisus.app" class="channel">
        <div class="ch-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="#FF2D78" stroke-width="1.6"/><path d="M3 7l9 7 9-7" stroke="#FF2D78" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="ch-body">
          <h3>Consultas generales</h3>
          <p>hola@gisus.app</p>
        </div>
        <svg class="ch-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="mailto:privacidad@gisus.app" class="channel">
        <div class="ch-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="#FF2D78" stroke-width="1.6" stroke-linejoin="round"/></svg>
        </div>
        <div class="ch-body">
          <h3>Privacidad y datos</h3>
          <p>privacidad@gisus.app</p>
        </div>
        <svg class="ch-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="mailto:seguridad@gisus.app" class="channel">
        <div class="ch-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="#FF2D78" stroke-width="1.6" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke="#FF2D78" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="ch-body">
          <h3>Reporte de seguridad</h3>
          <p>seguridad@gisus.app</p>
        </div>
        <svg class="ch-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="mailto:prensa@gisus.app" class="channel">
        <div class="ch-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 22h16a2 2 0 002-2V4a2 2 0 00-2-2H8a2 2 0 00-2 2v16a2 2 0 01-2 2zm0 0a2 2 0 01-2-2v-9c0-1.1.9-2 2-2h2" stroke="#FF2D78" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><path d="M18 14h-8M18 18h-8M18 10h-8" stroke="#FF2D78" stroke-width="1.6" stroke-linecap="round"/></svg>
        </div>
        <div class="ch-body">
          <h3>Prensa y medios</h3>
          <p>prensa@gisus.app</p>
        </div>
        <svg class="ch-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

    <!-- Form + info -->
    <div class="contact-main">
      <div class="form-col fade">
        <h2 class="form-title">Escríbenos directamente</h2>
        <p class="form-sub">Respondemos en menos de 48 horas laborables.</p>

        <form class="contact-form" id="contact-form" novalidate>
          <div class="field-row">
            <div class="field">
              <label for="nombre">Nombre</label>
              <input type="text" id="nombre" name="nombre" placeholder="Tu nombre" autocomplete="name" />
            </div>
            <div class="field">
              <label for="email">Email <span class="req">*</span></label>
              <input type="email" id="email" name="email" placeholder="tu@email.com" autocomplete="email" required />
            </div>
          </div>
          <div class="field">
            <label for="asunto">Asunto <span class="req">*</span></label>
            <select id="asunto" name="asunto" required>
              <option value="" disabled selected>Selecciona un tema…</option>
              <option value="general">Consulta general</option>
              <option value="cuenta">Problema con mi cuenta</option>
              <option value="privacidad">Solicitud de privacidad / RGPD</option>
              <option value="seguridad">Reporte de seguridad</option>
              <option value="colaboracion">Colaboración o prensa</option>
              <option value="otro">Otro</option>
            </select>
          </div>
          <div class="field">
            <label for="mensaje">Mensaje <span class="req">*</span></label>
            <textarea id="mensaje" name="mensaje" placeholder="Cuéntanos en qué podemos ayudarte…" rows="6" required></textarea>
          </div>
          <div class="field field-check">
            <label class="check-label">
              <input type="checkbox" id="privacidad-check" required />
              <span class="check-box"></span>
              <span>He leído y acepto la <a href="/privacidad">Política de Privacidad</a></span>
            </label>
          </div>
          <button type="submit" class="btn-submit">
            <span class="btn-text">Enviar mensaje</span>
            <span class="btn-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M22 2L11 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M22 2L15 22l-4-9-9-4 20-7z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </button>

          <div class="form-success" id="form-success" hidden>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#FF2D78" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <p>Mensaje enviado. Te responderemos pronto.</p>
          </div>
        </form>
      </div>

      <aside class="info-col fade" style="transition-delay:.12s">
        <div class="info-card">
          <h3>Tiempo de respuesta</h3>
          <div class="resp-times">
            <div class="rt">
              <div class="rt-bar" style="--p:95%"></div>
              <div class="rt-label"><span>Consultas generales</span><strong>&lt; 48 h</strong></div>
            </div>
            <div class="rt">
              <div class="rt-bar" style="--p:80%"></div>
              <div class="rt-label"><span>Privacidad / RGPD</span><strong>&lt; 72 h</strong></div>
            </div>
            <div class="rt">
              <div class="rt-bar rt-urgent" style="--p:100%"></div>
              <div class="rt-label"><span>Seguridad crítica</span><strong>&lt; 4 h</strong></div>
            </div>
          </div>
        </div>

        <div class="info-card">
          <h3>Redes sociales</h3>
          <div class="social-links">
            <a href="#" class="social-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.6"/><circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"/></svg>
              <span>Instagram</span>
              <span class="sl-handle">@gisusapp</span>
            </a>
            <a href="#" class="social-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M14 3v11.5a3.5 3.5 0 11-3-3.46V8a6.5 6.5 0 106 6.5V8.5a5.5 5.5 0 003.5 1.3V6.4A3.4 3.4 0 0114 3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
              <span>TikTok</span>
              <span class="sl-handle">@gisusapp</span>
            </a>
            <a href="#" class="social-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M3 3l7.5 9.5L3.5 21H6l5.3-6.3L16 21h5l-8-10.2L20.3 3H18l-5 5.9L8.5 3H3z" fill="currentColor"/></svg>
              <span>X / Twitter</span>
              <span class="sl-handle">@gisusapp</span>
            </a>
          </div>
        </div>

        <div class="info-card accent-card">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke="white" stroke-width="1.6" stroke-linejoin="round"/></svg>
          <h3>¿Usas la app y necesitas ayuda urgente?</h3>
          <p>Abre Gisus → Perfil → Ayuda y soporte. Nuestro equipo puede acceder al contexto de tu cuenta para resolverlo más rápido.</p>
        </div>
      </aside>
    </div>
  </div>

  <Footer />
</Layout>

<style>
  .contact-wrap {
    max-width: 1240px;
    margin: 0 auto;
    padding: 80px 32px 120px;
  }

  /* Channels */
  .channels {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 72px;
  }
  .channel {
    display: flex;
    align-items: center;
    gap: 14px;
    background: var(--cream);
    border-radius: 20px;
    padding: 20px 18px;
    text-decoration: none;
    color: var(--ink);
    transition: background .2s, transform .2s;
    border: 1.5px solid transparent;
  }
  .channel:hover { background: var(--pink-softer); border-color: var(--pink-soft); transform: translateY(-3px); }
  .ch-icon { width: 46px; height: 46px; background: var(--pink-softer); border-radius: 13px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .ch-body { flex: 1; min-width: 0; }
  .ch-body h3 { font-family: var(--font-display); font-weight: 700; font-size: 14px; margin-bottom: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .ch-body p { font-size: 13px; color: var(--pink); font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .ch-arrow { color: var(--ink-faint); flex-shrink: 0; transition: color .2s, transform .2s; }
  .channel:hover .ch-arrow { color: var(--pink); transform: translateX(3px); }

  /* Main grid */
  .contact-main {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 56px;
    align-items: start;
  }

  /* Form */
  .form-title { font-family: var(--font-display); font-weight: 800; font-size: 32px; letter-spacing: -0.02em; margin-bottom: 8px; }
  .form-sub { font-size: 16px; color: var(--ink-soft); margin-bottom: 36px; }
  .contact-form { display: flex; flex-direction: column; gap: 20px; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .field { display: flex; flex-direction: column; gap: 8px; }
  .field label { font-family: var(--font-display); font-weight: 700; font-size: 14px; color: var(--ink); }
  .req { color: var(--pink); }
  .field input, .field select, .field textarea {
    background: var(--cream);
    border: 1.5px solid var(--line);
    border-radius: 14px;
    padding: 14px 18px;
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--ink);
    outline: none;
    transition: border-color .2s, box-shadow .2s;
    appearance: none;
    -webkit-appearance: none;
    width: 100%;
  }
  .field input::placeholder, .field textarea::placeholder { color: var(--ink-faint); }
  .field input:focus, .field select:focus, .field textarea:focus {
    border-color: var(--pink);
    box-shadow: 0 0 0 3px rgba(255,45,120,.1);
    background: var(--white);
  }
  .field textarea { resize: vertical; min-height: 140px; }
  .field select { background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l5 5 5-5' stroke='%231E1418' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E"); background-repeat: no-repeat; background-position: right 18px center; padding-right: 44px; cursor: pointer; }

  .field-check { flex-direction: row; gap: 12px; align-items: center; }
  .check-label { display: flex; align-items: flex-start; gap: 12px; cursor: pointer; font-size: 15px; color: var(--ink-soft); line-height: 1.5; }
  .check-label input[type="checkbox"] { position: absolute; opacity: 0; width: 0; height: 0; }
  .check-box {
    width: 20px; height: 20px; border-radius: 6px; border: 1.5px solid var(--line);
    background: var(--cream); flex-shrink: 0; margin-top: 2px;
    transition: all .18s; position: relative;
  }
  .check-label input:checked + .check-box { background: var(--pink); border-color: var(--pink); }
  .check-label input:checked + .check-box::after {
    content: ''; position: absolute; left: 4px; top: 1px;
    width: 9px; height: 5px; border-left: 2px solid #fff; border-bottom: 2px solid #fff;
    transform: rotate(-45deg);
  }
  .check-label a { color: var(--pink); text-decoration: underline; text-underline-offset: 2px; }

  .btn-submit {
    background: var(--grad); color: #fff; border: none; cursor: pointer;
    font-family: var(--font-display); font-weight: 700; font-size: 16px;
    padding: 16px 32px; border-radius: 100px;
    display: inline-flex; align-items: center; gap: 10px; align-self: flex-start;
    transition: transform .2s, box-shadow .2s;
  }
  .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(255,45,120,.35); }
  .btn-submit:active { transform: none; }

  .form-success {
    display: flex; align-items: center; gap: 12px;
    background: var(--pink-softer); border: 1px solid var(--pink-soft);
    border-radius: 14px; padding: 16px 20px;
  }
  .form-success p { font-size: 15px; font-weight: 600; color: var(--ink); margin: 0; }
  .form-success[hidden] { display: none; }

  /* Info col */
  .info-col { display: flex; flex-direction: column; gap: 20px; }
  .info-card { background: var(--cream); border-radius: 22px; padding: 26px; }
  .info-card h3 { font-family: var(--font-display); font-weight: 800; font-size: 17px; margin-bottom: 18px; }

  .resp-times { display: flex; flex-direction: column; gap: 14px; }
  .rt { display: flex; flex-direction: column; gap: 6px; }
  .rt-bar {
    height: 6px; border-radius: 100px; background: var(--line); overflow: hidden; position: relative;
  }
  .rt-bar::after {
    content: ''; position: absolute; inset-block: 0; left: 0;
    width: var(--p); background: var(--grad); border-radius: 100px;
  }
  .rt-bar.rt-urgent::after { background: linear-gradient(90deg, #FF2D78, #FF6B9D); }
  .rt-label { display: flex; justify-content: space-between; align-items: center; }
  .rt-label span { font-size: 13px; color: var(--ink-soft); }
  .rt-label strong { font-size: 13px; font-weight: 700; color: var(--ink); }

  .social-links { display: flex; flex-direction: column; gap: 10px; }
  .social-link {
    display: flex; align-items: center; gap: 12px;
    color: var(--ink); text-decoration: none; font-size: 15px; font-weight: 600;
    padding: 10px 14px; border-radius: 12px; transition: background .18s;
  }
  .social-link:hover { background: var(--pink-softer); color: var(--pink); }
  .sl-handle { margin-left: auto; font-size: 13px; font-weight: 500; color: var(--ink-faint); }

  .accent-card {
    background: var(--grad); color: #fff;
    display: flex; flex-direction: column; gap: 12px;
  }
  .accent-card h3 { color: #fff; margin-bottom: 4px; }
  .accent-card p { font-size: 14px; color: rgba(255,255,255,.82); line-height: 1.55; margin: 0; }

  @media (max-width: 980px) {
    .channels { grid-template-columns: 1fr 1fr; }
    .contact-main { grid-template-columns: 1fr; }
    .info-col { flex-direction: row; flex-wrap: wrap; }
    .info-card { flex: 1; min-width: 260px; }
  }
  @media (max-width: 560px) {
    .contact-wrap { padding: 48px 20px 80px; }
    .channels { grid-template-columns: 1fr; }
    .field-row { grid-template-columns: 1fr; }
    .info-col { flex-direction: column; }
  }
</style>

<script>
  const io = new IntersectionObserver(
    (es) => { es.forEach(e => { if (e.isIntersecting) e.target.classList.add('in'); }); },
    { threshold: .1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.fade').forEach(el => io.observe(el));

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success')!;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    const btn = form.querySelector('.btn-submit') as HTMLButtonElement;
    btn.disabled = true;
    btn.querySelector('.btn-text')!.textContent = 'Enviando…';
    setTimeout(() => {
      form.reset();
      btn.disabled = false;
      btn.querySelector('.btn-text')!.textContent = 'Enviar mensaje';
      success.hidden = false;
      setTimeout(() => { success.hidden = true; }, 6000);
    }, 1200);
  });
</script>
